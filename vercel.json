{
  "buildCommand": "npm run build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_APP_NAME": "Keystone Web"
  },
  "crons": [
    {
      "path": "/api/cron/check-domain-transfers",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/send-transfer-reminders",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/parked-domain-renewal",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/marketing-sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/marketing-budget-check",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/leads/discover",
      "schedule": "0 14 * * 1-5"
    },
    {
      "path": "/api/cron/leads/audit",
      "schedule": "30 14 * * 1-5"
    },
    {
      "path": "/api/cron/leads/autopilot",
      "schedule": "0 14,16,18,20 * * 1-5"
    }
  ]
}
