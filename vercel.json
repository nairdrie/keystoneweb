{
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_APP_NAME": "Keystone Web"
  },
  "crons": [
    {
      "path": "/api/cron/check-domain-transfers",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/send-transfer-reminders",
      "schedule": "0 15 * * *"
    }
  ]
}
